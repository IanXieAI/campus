.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(0, 86, 179, 0.1), transparent 30%),
    linear-gradient(180deg, #f4f8ff 0%, #eef4ff 100%);
}

.container {
  padding: 30rpx;
  padding-bottom: 180rpx;
}

.hero-card {
  background: linear-gradient(135deg, #00205b 0%, #0d4aa5 100%);
  color: #ffffff;
}

.hero-card .title,
.hero-card .text,
.hero-card .text-muted {
  color: #ffffff;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #f8faff;
  border: 2rpx solid rgba(0, 32, 91, 0.08);
  box-sizing: border-box;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.action-btn,
.footer-btn {
  flex: 1;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item,
.photo-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
}

.photo-image {
  width: 100%;
  height: 100%;
  background: #dbe7ff;
}

.photo-mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 32, 91, 0.55);
  color: #ffffff;
  font-size: 26rpx;
}

.photo-badge {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #ffffff;
}

.success-badge {
  background: rgba(0, 168, 89, 0.92);
}

.error-badge {
  background: rgba(230, 57, 70, 0.92);
  bottom: 56rpx;
}

.photo-delete,
.photo-retry {
  position: absolute;
  right: 10rpx;
  min-width: 88rpx;
  line-height: 1.6;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #ffffff;
  border: none;
}

.photo-delete {
  top: 10rpx;
  background: rgba(230, 57, 70, 0.95);
}

.photo-retry {
  bottom: 10rpx;
  background: rgba(0, 32, 91, 0.9);
}

.photo-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed rgba(0, 32, 91, 0.25);
  background: rgba(255, 255, 255, 0.76);
  color: #00205b;
}

.photo-add-plus {
  font-size: 64rpx;
  line-height: 1;
}

.photo-add-text {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.result-card {
  border: 2rpx solid rgba(0, 32, 91, 0.06);
}

.result-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.result-item,
.issue-box,
.location-box {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #f8faff;
}

.result-value {
  margin-top: 8rpx;
  color: #00205b;
  font-size: 30rpx;
  font-weight: 600;
}

.severity-row {
  margin-top: 16rpx;
}

.location-title {
  margin-bottom: 0;
}

.status-passed {
  background: rgba(0, 168, 89, 0.08);
}

.status-pending {
  background: rgba(0, 86, 179, 0.08);
}

.status-warning {
  background: rgba(230, 57, 70, 0.08);
}

.warning-text {
  margin-top: 12rpx;
}

.mini-action {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  line-height: 1.2;
  color: #00205b;
  background: #ffffff;
  border: 2rpx solid rgba(0, 32, 91, 0.15);
  border-radius: 999rpx;
}

.footer-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(248, 250, 255, 0.96);
  box-shadow: 0 -8rpx 24rpx rgba(0, 32, 91, 0.08);
}

button {
  border: none;
}