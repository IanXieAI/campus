<view class="page">
  <view class="container">
    <view class="card hero-card">
      <view class="title">巡查录入</view>
      <view class="text text-muted">支持文字、语音和现场照片，提交前可直接预览照片清晰度。</view>
    </view>

    <view class="card">
      <view class="section-header">
        <view class="subtitle">巡查描述</view>
        <view class="text-muted">{{wordCount}} 字</view>
      </view>
      <textarea
        class="textarea"
        placeholder="请输入巡查描述，或使用语音输入"
        value="{{aiInput}}"
        maxlength="300"
        bindinput="handleInput"
      />
      <view class="action-row">
        <button class="btn-secondary action-btn" bindtap="handleVoiceInput">
          {{isRecording ? '停止录音' : '语音输入'}}
        </button>
        <button class="btn-primary action-btn" loading="{{analyzing}}" bindtap="analyzeInput">
          智能分析
        </button>
      </view>
    </view>

    <view class="card">
      <view class="section-header">
        <view class="subtitle">现场照片</view>
        <view class="text-muted">最多 3 张</view>
      </view>
      <view class="text text-muted mb-1">照片上传后可点击原地预览，确认是否清晰。</view>
      <view class="photo-grid">
        <block wx:for="{{photos}}" wx:key="id">
          <view class="photo-item">
            <image
              class="photo-image"
              src="{{item.tempFilePath}}"
              mode="aspectFill"
              data-url="{{item.tempFilePath}}"
              bindtap="previewPhoto"
            />
            <view wx:if="{{item.uploading}}" class="photo-mask">上传中</view>
            <view wx:elif="{{item.uploaded}}" class="photo-badge success-badge">已上传</view>
            <view wx:if="{{item.error}}" class="photo-badge error-badge">上传失败</view>
            <button class="photo-delete" data-id="{{item.id}}" catchtap="removePhoto">删除</button>
            <button wx:if="{{item.error}}" class="photo-retry" data-id="{{item.id}}" catchtap="retryUploadPhoto">重试</button>
          </view>
        </block>

        <button wx:if="{{photos.length < 3}}" class="photo-add" bindtap="choosePhotos">
          <view class="photo-add-plus">+</view>
          <view class="photo-add-text">拍摄/选择</view>
        </button>
      </view>
    </view>

    <view wx:if="{{aiResult}}" class="card result-card">
      <view class="section-header">
        <view class="subtitle">AI分析结果</view>
        <view class="tag {{aiResult.result === '正常' ? 'tag-success' : 'tag-danger'}}">{{aiResult.result}}</view>
      </view>

      <view class="result-grid">
        <view class="result-item">
          <view class="text-muted">校区</view>
          <view class="result-value">{{aiResult.campus}}</view>
        </view>
        <view class="result-item">
          <view class="text-muted">地点</view>
          <view class="result-value">{{aiResult.location}}</view>
        </view>
      </view>

      <view wx:if="{{aiResult.result !== '正常'}}" class="issue-box">
        <view class="text-muted">隐患描述</view>
        <view class="result-value">{{aiResult.issue}}</view>
        <view class="severity-row">
          <view class="tag {{aiResult.severity === 'high' ? 'tag-danger' : aiResult.severity === 'medium' ? 'tag-warning' : 'tag-success'}}">
            {{aiResult.severity === 'high' ? '高危' : aiResult.severity === 'medium' ? '中等' : '轻微'}}
          </view>
        </view>
      </view>

      <view class="location-box {{locationCheckStatus === 'passed' ? 'status-passed' : locationCheckStatus === 'checking' || locationCheckStatus === 'locating' ? 'status-pending' : 'status-warning'}}">
        <view class="section-header">
          <view class="subtitle location-title">位置校验</view>
          <button wx:if="{{locationName}}" class="mini-action" bindtap="verifyLocation" data-location="{{locationName}}">重新校验</button>
        </view>
        <view class="text {{locationCheckStatus === 'passed' ? 'text-success' : locationCheckStatus === 'checking' || locationCheckStatus === 'locating' ? 'text-primary' : 'text-danger'}}">
          {{locationCheckStatus === 'passed' ? '位置验证通过' : locationCheckStatus === 'checking' ? '位置校验中...' : locationCheckStatus === 'locating' ? '正在获取当前位置...' : '位置验证未通过'}}
        </view>
        <view wx:if="{{locationWarningMessage}}" class="text warning-text">{{locationWarningMessage}}</view>
        <view wx:if="{{locationDistance !== null}}" class="text text-muted">距离目标地点约 {{locationDistance}} 米</view>
      </view>
    </view>

    <view class="footer-actions">
      <button class="btn-secondary footer-btn" bindtap="resetInput">重新录入</button>
      <button class="btn-primary footer-btn" bindtap="confirmInspection">确认上报</button>
    </view>
  </view>
</view>